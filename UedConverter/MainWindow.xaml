<Window x:Class="UedConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UedConverter"
        xmlns:c="clr-namespace:UedConverter.Components"
        mc:Ignorable="d"
        Title="UedConverter" Width="639" ResizeMode="CanMinimize" SizeToContent="Height">
    <StackPanel Background="{DynamicResource Background}">
        <GroupBox Header="T3D -> OBJ" x:Name="U2O_Group" Drop="File_Drop" AllowDrop="True" DragLeave="File_DragLeave" DragEnter="File_DragEnter">
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <Button Content="File" Width="100" Margin="4" Click="U2O_File_Click"/>
                    <TextBlock x:Name="U2O_File_Textbox" Margin="4" Padding="4" Text="" Style="{DynamicResource TB_Path}" />
                </DockPanel>
                <DockPanel LastChildFill="True">
                    <Button Content="Destination" Width="100" Margin="4" Click="U2O_Destination_Click"/>
                    <TextBlock x:Name="U2O_Destination_Textbox" Margin="4" Padding="4" Text="" Style="{DynamicResource TB_Path}" />
                </DockPanel>
                <CheckBox x:Name="calculateTxSpaceChBox" Margin="5" IsEnabled="False">Calculate Texture Space (Experimental. Requires file with texture sizes)</CheckBox>
                <c:CenterFirstPanel>
                    <Button Content="Convert" Height="25" Margin="5" HorizontalAlignment="Center" Width="100" Click="U2O_Convert_Click" />
                    <c:FadingMark x:Name="U2O_Mark" VerticalAlignment="Center"/>
                </c:CenterFirstPanel>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="OBJ -> T3D" x:Name="O2U_Group" Drop="File_Drop" AllowDrop="True" DragLeave="File_DragLeave" DragEnter="File_DragEnter">
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <Button Content="File" Width="100" Margin="4" Click="O2U_File_Click"/>
                    <TextBlock x:Name="O2U_File_Textbox" Margin="4" Padding="4" Text="" Style="{DynamicResource TB_Path}" />
                </DockPanel>
                <DockPanel LastChildFill="True">
                    <Button Content="Destination" Width="100" Height="25" Margin="4" Click="O2U_Destination_Click"/>
                    <TextBlock x:Name="O2U_Destination_Textbox" Margin="4" Padding="4" Text="" Style="{DynamicResource TB_Path}" />
                </DockPanel>
                <c:CenterFirstPanel>
                    <Button Content="Convert" Height="25" Margin="5" HorizontalAlignment="Center" Width="100" Click="O2U_Convert_Click"/>
                    <c:FadingMark x:Name="O2U_Mark" VerticalAlignment="Center"/>
                </c:CenterFirstPanel>
            </StackPanel>
        </GroupBox>
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="?" Width="25" Margin="5 0" Click="About_Click"/>
            <Button Content="Open UTX (Experimental)" Margin="5 0" Padding="5 0" Click="OpenUtx_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
