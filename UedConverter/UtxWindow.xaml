<Window x:Class="UedConverter.UtxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UedConverter"
        mc:Ignorable="d"
        Title="UtxWindow" MinWidth="840" MinHeight="512" MaxHeight="640"  SizeToContent="WidthAndHeight"
        Background="{DynamicResource Background}">
    <Window.Resources>
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
    </Window.Resources>
    <Grid ShowGridLines="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400px"/>
            <ColumnDefinition Width="512px"/>
        </Grid.ColumnDefinitions>

        <Image x:Name="imageBox" Grid.Column="1" Height="512" Width="512"/>
        <Grid Grid.Column="0" Width="400px">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>
            <TreeView x:Name="treeView" Grid.Row="0" SelectedItemChanged="TreeNodeSelected" Background="{DynamicResource Background}" Foreground="{DynamicResource Text}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding ChildElements}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock MinWidth="80" Text="{Binding Name}" Padding="5 0" Foreground="{DynamicResource Text}"/>
                            <Border Width="20" Background="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" />
                            <Image Stretch="Uniform" Width="Auto" Height="Auto" MaxHeight="20" RenderOptions.BitmapScalingMode="NearestNeighbor" Source="{Binding Palette}" />
                            <TextBlock Text="{Binding Value}" Padding="5 0" Foreground="{DynamicResource Text}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <TextBox x:Name="rawBox" Grid.Row="1" Background="{DynamicResource Background}" Foreground="{DynamicResource Text}" />
        </Grid>
    </Grid>
</Window>
