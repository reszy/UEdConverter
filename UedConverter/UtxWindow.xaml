<Window x:Class="UedConverter.UtxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UedConverter"
        mc:Ignorable="d"
        Title="Utx Data Browser" MinWidth="840" MinHeight="512" SizeToContent="Width"
        Background="{DynamicResource Background}">
    <Window.Resources>
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <local:ColorToHexConverter x:Key="ColorToHexConverter"/>
    </Window.Resources>
    <Grid ShowGridLines="True" ColumnDefinitions="550px, 512px">
        <Image x:Name="imageBox" Grid.Column="1" Height="512" Width="512"/>
        <Grid Grid.Column="0" Width="550px" RowDefinitions="*, 150">
            <TreeView x:Name="treeView" Grid.Row="0" SelectedItemChanged="TreeNodeSelected" Background="{DynamicResource Background}" Foreground="{DynamicResource Text}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding ChildElements}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock MinWidth="110" Text="{Binding Name}" Padding="5 0" Foreground="{DynamicResource Text}"/>
                            <Image Stretch="Uniform" Width="Auto" Height="16" MaxHeight="20" RenderOptions.BitmapScalingMode="NearestNeighbor" Source="{Binding InlineImage}" />
                            <Border Width="10" Height="10" Background="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" ToolTip="{Binding Color, Converter={StaticResource ColorToHexConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Color}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="{Binding Value}" Padding="5 0" Foreground="{DynamicResource Text}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
            <DockPanel Grid.Row="1" LastChildFill="True">
                <TextBlock x:Name="BottomText" DockPanel.Dock="Bottom" Foreground="{DynamicResource Text}"/>
                <TextBox x:Name="rawBox" DockPanel.Dock="Top" Background="{DynamicResource Background}" Foreground="{DynamicResource Text}" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Liberation Mono"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
